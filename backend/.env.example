# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
# Basis-Pfad der API (entspricht der Swagger-Spec: http://localhost:3000/v1)
API_BASE_PATH=/v1
# Öffentlich erreichbare Basis-URL (für Redirect URIs und Download-Links).
PUBLIC_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Datenbank (PostgreSQL)
# Bei docker-compose ist der Host der Service-Name "db".
# ----------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-postgres-password
# Optional: vollständige Connection-URL. Überschreibt die Einzelwerte oben.
# DATABASE_URL=postgres://appuser:change-me@db:5432/appdb

# ----------------------------------------------------------------------------
# JWT / Tokens
# WICHTIG: In Produktion durch lange, zufällige Werte ersetzen!
# z.B. erzeugen mit:  openssl rand -hex 48
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-please-use-openssl-rand
JWT_REFRESH_SECRET=change-me-refresh-secret-please-use-openssl-rand
JWT_STATE_SECRET=change-me-state-secret-please-use-openssl-rand
COOKIE_SECRET=change-me-cookie-secret-please-use-openssl-rand
# Lebensdauer Access Token in Sekunden (default 1h)
ACCESS_TOKEN_TTL=3600
# Lebensdauer Refresh Token in Sekunden (default 30 Tage)
REFRESH_TOKEN_TTL=2592000

# ----------------------------------------------------------------------------
# Google OAuth 2.0 / OpenID Connect
# Werte aus der Google Cloud Console (siehe README).
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=example
GOOGLE_CLIENT_SECRET=example
# Muss exakt mit der in der Google Console hinterlegten Redirect URI übereinstimmen:
GOOGLE_REDIRECT_URI=http://localhost:3000/v1/auth/oauth/google/callback

# Ziel-Seite nach erfolgreichem Login (Tokens werden im URL-Fragment übergeben).
POST_LOGIN_REDIRECT=http://localhost:3000/test-oauth

# ----------------------------------------------------------------------------
# Datei-Uploads
# ----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
