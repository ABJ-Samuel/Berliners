PORT=3000

# Local Postgres from docker-compose.yml at repo root:
DATABASE_URL=postgres://rag:rag@localhost:5432/rag

# ---- Vertex AI (embeddings) ----
# Required to ingest PDFs (chunk embeddings) and to retrieve context.
# Needs the Vertex AI API enabled on the project and ADC with roles/aiplatform.user:
#   gcloud auth application-default login
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
VERTEX_EMBEDDING_MODEL=text-embedding-004

# GCS (optional for ingestion storage). With DISABLE_GCS=true, PDFs are stored on
# local disk (STORAGE_DIR) instead of GCS.
GCS_BUCKET=your-gcs-bucket
DISABLE_GCS=true

# ---- LLM generation (Claude) ----
# Required for the metadata agent, the 5 recommendation agents, and /fit.
# Without it, ingestion still succeeds (metadata is best-effort) but recommendation
# and /fit will fail with a clear error.
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ---- Lab2Venture: upload limits, storage, pipeline behaviour ----
MAX_UPLOAD_MB=20
MAX_PAGES=50
STORAGE_DIR=./storage
# When true, completing the ingestion job auto-enqueues a (separate) recommendation job.
AUTO_RECOMMEND=false
# Chunks retrieved per fixed query when building the context package.
CONTEXT_PER_QUERY_K=4

# ---- Chunking / retrieval knobs ----
CHUNK_TARGET_TOKENS=700
CHUNK_OVERLAP_TOKENS=120
RETRIEVE_CANDIDATES=10
RETRIEVE_TOP_K=5
