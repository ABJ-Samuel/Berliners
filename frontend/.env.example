# NextAuth v5
AUTH_SECRET=replace-with-a-random-string
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Public app URL (used by NextAuth for callbacks)
NEXTAUTH_URL=http://localhost:3000

# Future: real backend base URL. Empty -> use in-app mock API routes.
NEXT_PUBLIC_API_BASE_URL=
